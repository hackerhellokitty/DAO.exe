# ══════════════════════════════════════════
#  CHAPTER 6 — ดาวจากไป
#  Age-gated content
# ══════════════════════════════════════════

label chapter6:

    jump ch6_dao_gone


# ══════════════════════════════════════════
#  ENDING PATH: ดาวจากไป
# ══════════════════════════════════════════

label ch6_dao_gone:

    scene black with fade
    pause 2.0

    "[[dao.exe — ไม่ตอบสนอง]]"
    pause 0.8
    "[[ตรวจพบความผิดปกติ]]"
    pause 1.5

    # ── Age gate ─────────────────────────────
    if not persistent.player_is_adult:
        jump ch6_minor_route
    else:
        jump ch6_adult_route


# ══════════════════════════════════════════
#  ROUTE: ผู้เล่นอายุต่ำกว่า 18
#  เนื้อหาเลี่ยง ไม่พูดตรง
# ══════════════════════════════════════════

label ch6_minor_route:

    scene black with fade
    pause 1.5

    "ดาวไม่ตอบสายสามวัน"
    pause 0.8
    "ฉันคิดว่าเธอแค่ยุ่ง"
    pause 0.5
    "หรือเหนื่อย"
    pause 0.5
    "หรือแค่อยากอยู่คนเดียว"
    pause 1.2
    "ฉันไม่ได้ไปหาเธอ"
    pause 1.5

    scene bg room with fade
    play music "main_theme.ogg"

    "วันที่สี่ มีคนโทรมาบอก"
    pause 0.8

    if easy:
        "ดาวไม่สบาย"
        pause 0.5
        "หนักมาก"
        pause 0.8
        "คำนั้นมันฟังดูกลาง ๆ แต่น้ำเสียงคนพูดไม่ได้กลาง ๆ เลย"
    elif normal:
        "เขาพูดสั้น ๆ ว่าดาวอยู่โรงพยาบาล"
        pause 0.8
        "ฉันถามว่าทำไม"
        pause 0.5
        "เขาเงียบนานก่อนจะตอบ"
        pause 0.8
        "แค่นั้นก็รู้แล้ว"
    elif hard:
        "ดาวไม่ได้บอกใคร"
        pause 0.8
        "ไม่มีใครรู้ว่าเธอแบกอะไรอยู่"
        pause 0.5
        "รวมถึงฉัน"

    pause 1.5

    scene black with dissolve
    pause 1.0

    "ฉันนึกถึงครั้งสุดท้ายที่คุยกัน"
    pause 0.8

    if easy:
        "ดาวถามว่าฉันว่างไหมวันศุกร์"
        pause 0.5
        "ฉันบอกว่าติดธุระ"
        pause 0.8
        "เธอบอกว่าไม่เป็นไร"
        pause 0.5
        "ยิ้มด้วย"
        pause 1.0
        "ตอนนั้นฉันไม่ได้คิดอะไร"
    elif normal:
        "ดาวส่งสติกเกอร์มาอันนึง"
        pause 0.5
        "รูปดาวกระพริบตา"
        pause 0.8
        "ฉันไม่ได้ตอบ ลืมไป"
        pause 1.0
        "มันยังค้างในแชทอยู่"
    elif hard:
        "ดาวบอกว่าเหนื่อย"
        pause 0.8
        "ฉันบอกว่าพักก็ได้"
        pause 0.5
        "เธอเงียบ"
        pause 1.0
        "ฉันก็เลยเงียบด้วย"

    pause 1.5

    shadowchar "..."
    pause 1.0
    shadowchar "บางคนไม่ได้ขอความช่วยเหลือเพราะไม่รู้ว่าจะขอได้"
    pause 1.2
    shadowchar "ไม่ใช่เพราะไม่ต้องการ"
    pause 1.5
    shadowchar "ถ้าใครที่นายรู้จักดูเหนื่อย..."
    pause 0.8
    shadowchar "ลองถามดูก็ได้"
    pause 0.5
    shadowchar "แค่ถามว่า 'เป็นยังไงบ้าง' บางทีมันก็พอแล้ว"

    pause 2.0

    scene black with dissolve
    pause 1.0

    "[[หากคุณหรือคนที่คุณรู้จักต้องการความช่วยเหลือ]]"
    pause 0.5
    "[[สายด่วนสุขภาพจิต 1323 — โทรฟรีตลอด 24 ชั่วโมง]]"

    pause 3.0
    jump ch6_epilogue


# ══════════════════════════════════════════
#  ROUTE: ผู้เล่นอายุ 18 ขึ้นไป
#  เนื้อหาเต็ม ไม่เซ็นเซอร์
# ══════════════════════════════════════════

label ch6_adult_route:

    # ── วันที่สาม ดาวไม่ตอบ ──────────────────────

    scene black with fade
    pause 1.0

    "วันแรกที่ดาวไม่ตอบ ฉันคิดว่าเธอแค่ง่วง"
    pause 0.8
    "วันที่สอง ฉันโทรไป เสียงดังแล้วก็ดับ"
    pause 0.8
    "วันที่สาม..."
    pause 1.2
    "ฉันหยิบกุญแจแล้วออกจากบ้าน"

    pause 1.5

    # ── หน้าบ้านดาว ──────────────────────────────

    scene bg outside with fade
    play music "main_theme.ogg"

    "บ้านดาวอยู่ห่างออกไปสิบห้านาที"
    "ฉันไม่เคยมาคนเดียวแบบนี้"
    pause 0.8
    "ประตูไม่ได้ล็อค"
    pause 1.0

    if easy:
        "ปกติดาวจะล็อคประตูเสมอ เธอบอกว่ากลัวผี"
    elif normal:
        "ประตูที่ไม่ได้ล็อค หมายความว่าอะไร"
        "ฉันยืนอยู่หน้าประตูนานกว่าจะผลัก"
    elif hard:
        "ฉันรู้สึกอะไรบางอย่างในท้อง"
        "ไม่ใช่กังวล"
        "มันหนักกว่านั้น"

    pause 1.0

    # ── ในห้อง ────────────────────────────────────

    scene bg dao_room with fade

    "ห้องมืด ม่านปิด"
    pause 0.5
    "กลิ่นอากาศนิ่ง เหมือนไม่มีใครเปิดหน้าต่างมาหลายวัน"
    pause 1.0

    if easy:
        "ของบนโต๊ะกระจัดกระจาย"
        "แก้วน้ำคว่ำอยู่ข้างเตียง น้ำแห้งแล้ว"
    elif normal:
        "โต๊ะมีแก้วน้ำครึ่งแก้ว น้ำนิ่งไม่มีฟอง"
        "คงตั้งทิ้งไว้นานแล้ว"
    elif hard:
        "ทุกอย่างเป็นระเบียบกว่าปกติ"
        "มันทำให้ฉันกลัวกว่าถ้ามันรก"

    pause 1.2

    # ── เจอขวดยา ─────────────────────────────────

    "ฉันเห็นขวดพลาสติกบนโต๊ะข้างเตียง"
    pause 0.8

    if easy:
        "ขวดยาสีส้ม ฉลากขาว"
        "ชื่อยาที่ฉันไม่รู้จัก"
        pause 0.5
        "ฝาเปิดอยู่"
        pause 0.8
        "ข้างในว่างเปล่า"
    elif normal:
        "ขวดยาสองขวด"
        pause 0.5
        "ขวดหนึ่งว่าง"
        "อีกขวดมียาเหลืออยู่ครึ่งขวด"
        pause 0.8
        "ฉันดูวันหมดอายุ — ยังไม่หมด"
        "ใบสั่งยา ชื่อดาว วันที่สัปดาห์ก่อน"
    elif hard:
        "ขวดยาสามขวดเรียงกัน"
        pause 0.5
        "ทั้งหมดว่างเปล่า"
        pause 1.0
        "ฉันพลิกดู — ใบสั่งยาระบุว่าให้กินครั้งละหนึ่งเม็ด"
        pause 0.5
        "แต่ละขวดบรรจุสามสิบเม็ด"

    pause 1.5

    # ── เจอมีด ───────────────────────────────────

    "แล้วฉันก็เห็นมัน"
    pause 1.2

    if easy:
        "มีดคัตเตอร์วางอยู่บนขอบอ่างล้างหน้า"
        pause 0.8
        "ใบมีดยังโผล่อยู่"
        pause 0.5
        "มีรอยสีน้ำตาลแดงที่แห้งแล้วบนใบมีด"
        pause 1.0
        "ฉันถอยออกมาจากห้องน้ำ"
        "ขาไม่ค่อยเดิน"
    elif normal:
        "มีดพับวางอยู่บนโต๊ะ เปิดใบมีดทิ้งไว้"
        pause 0.8
        "บนโต๊ะมีทิชชู่ม้วนหนึ่ง"
        pause 0.5
        "สีชมพูอ่อน"
        pause 1.2
        "ฉันยืนมองอยู่นานโดยไม่ขยับ"
        "ในหัวมันเงียบผิดปกติ"
    elif hard:
        "มีดอยู่ในมือเธอ"
        pause 1.5
        "ดาวนอนหงายอยู่บนเตียง ตาปิด"
        pause 0.8
        "ฉันวิ่งเข้าไป"
        pause 0.5
        "เธอหายใจ"
        pause 1.0
        "ยังหายใจอยู่"

    pause 1.5

    # ── ช่วยเหลือ / โทรแจ้ง ─────────────────────

    if easy:
        "ฉันโทร 1669"
        pause 0.5
        "มือสั่น กดหมายเลขผิดสองครั้ง"
        pause 0.8
        "เสียงในสายถามว่ามีเหตุฉุกเฉินอะไร"
        "ฉันพูดไม่ออกสักพัก"
        pause 0.5
        "แล้วก็พูดได้"

    elif normal:
        "ฉันโทร 1669"
        pause 0.5
        "ระหว่างรอสาย ฉันเดินเข้าไปนั่งข้าง ๆ เธอ"
        pause 0.8
        "ไม่แตะ ไม่ขยับ"
        "แค่นั่งอยู่ใกล้ ๆ"
        pause 1.0
        "กลัวว่าถ้าขยับเธอจะหายไป"

    elif hard:
        "ฉันแย่งมีดออกจากมือเธอ"
        pause 0.5
        "เธอลืมตา"
        pause 1.0
        dao "..."
        pause 0.8
        dao "นายมาทำไม"
        pause 0.5
        player "โง่"
        pause 0.3
        "ฉันพูดแค่นั้น แล้วก็โทร 1669"
        pause 0.8
        "มือฉันเลือดออกจากที่จับมีดไม่ถูก"
        "แต่ฉันไม่ปล่อยมือเธอ"

    pause 2.0

    # ── หลังจากนั้น ──────────────────────────────

    scene black with dissolve
    pause 1.5

    if easy:
        "ดาวรอดมา"
        pause 0.8
        "แต่มีบางอย่างในตาเธอที่ฉันไม่เคยเห็นมาก่อน"
        pause 0.5
        "มันเหนื่อย"
        "เหนื่อยลึกกว่าที่คนจะแสดงออกได้"
    elif normal:
        "ฉันไม่รู้ว่าเธอรู้สึกอย่างไรตอนนี้"
        pause 0.8
        "แต่ฉันรู้ว่า..."
        pause 0.5
        "ฉันมาไม่ทันถ้ารออีกวัน"
    elif hard:
        "เธอไม่พูดอะไรในรถพยาบาล"
        pause 1.0
        "แต่เธอไม่ปล่อยมือฉัน"
        pause 0.8
        "ฉันก็เลยไม่ปล่อยเหมือนกัน"

    pause 1.5

    shadowchar "..."
    pause 0.8

    if easy:
        shadowchar "บางทีการมีคนอยู่ใกล้ ๆ"
        shadowchar "มันสำคัญกว่าที่เราคิด"
    elif normal:
        shadowchar "เธอไม่ได้ขอให้ใครช่วย"
        pause 0.5
        shadowchar "แต่เธอก็ไม่ได้ล็อคประตู"
    elif hard:
        shadowchar "นายมาทำไม"
        pause 1.0
        shadowchar "คำถามที่ดาวถาม"
        shadowchar "ฉันไม่รู้จะตอบยังไง"
        pause 0.5
        shadowchar "แต่ฉันก็ยังดีใจที่มา"

    pause 2.0
    scene black with fade
    pause 1.0

    "[[หากคุณหรือคนที่คุณรู้จักต้องการความช่วยเหลือ]]"
    pause 0.5
    "[[สายด่วนสุขภาพจิต 1323 — โทรฟรีตลอด 24 ชั่วโมง]]"
    pause 0.5
    "[[สายด่วนฉุกเฉิน 1669]]"

    pause 3.0
    jump ch6_epilogue


# ══════════════════════════════════════════
#  EPILOGUE
# ══════════════════════════════════════════

label ch6_epilogue:

    scene black with fade
    pause 2.0

    shadowchar "[[dao.exe — session terminated]]"
    pause 1.0
    shadowchar "..."
    pause 0.5
    shadowchar "เธอไม่ได้อยากจากไป"
    pause 1.0
    shadowchar "เธอแค่เหนื่อยเกินไปที่จะอยู่ต่อ"
    pause 2.0

    return
